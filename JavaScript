document.addEventListener('DOMContentLoaded', () => {
    // 1. ESTADO DO JOGO
    let state = {
        name: "Fazendeiro",
        skin: "🧑‍🌾",
        gold: 50,
        xp: 0,
        pos: { x: 500, y: 500 },
        wheatCount: 0,
        time: 8
    };

    const WORLD_SIZE = 3000;

    // 2. ELEMENTOS DOM
    const startScreen = document.getElementById('start-screen');
    const customScreen = document.getElementById('custom-screen');
    const gameContainer = document.getElementById('game-container');
    const playerEl = document.getElementById('player');
    const worldEl = document.getElementById('world');

    // --- FUNÇÕES DE NAVEGAÇÃO (CORRIGIDAS) ---

    // Botão NOVO JOGO
    document.getElementById('btn-new-game').addEventListener('click', () => {
        console.log("Botão Novo Jogo clicado");
        startScreen.style.setProperty('display', 'none', 'important');
        customScreen.style.setProperty('display', 'flex', 'important');
    });

    // Seleção de Personagem (Emojis)
    document.querySelectorAll('.skin-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            state.skin = btn.getAttribute('data-skin');
            document.getElementById('preview-emoji').innerText = state.skin;
            console.log("Skin selecionada:", state.skin);
        });
    });

    // Botão COMEÇAR AVENTURA
    document.getElementById('btn-start-adventure').addEventListener('click', () => {
        const inputName = document.getElementById('char-name').value;
        if (!inputName || inputName.trim() === "") {
            alert("Por favor, digite um nome para seu fazendeiro!");
            return;
        }
        
        state.name = inputName;
        customScreen.style.setProperty('display', 'none', 'important');
        gameContainer.style.display = 'block';
        initGame();
    });

    // Botão CARREGAR JOGO
    document.getElementById('btn-load-game').addEventListener('click', () => {
        const saved = localStorage.getItem('fazenda_save_v2');
        if (saved) {
            state = JSON.parse(saved);
            startScreen.style.display = 'none';
            gameContainer.style.display = 'block';
            initGame();
        } else {
            alert("Nenhum save encontrado! Inicie um Novo Jogo.");
        }
    });

    // --- LÓGICA DO MUNDO ---

    function initGame() {
        playerEl.innerText = state.skin;
        document.getElementById('display-name').innerText = state.name;
        updateUI();
        updateCamera();
        
        // Agricultura
        document.querySelectorAll('.plot').forEach(plot => {
            plot.onclick = () => { // Usando onclick direto para evitar múltiplos listeners
                if (plot.innerText === '🟫') {
                    plot.innerText = '🌱';
                    setTimeout(() => plot.innerText = '🌾', 5000);
                } else if (plot.innerText === '🌾') {
                    plot.innerText = '🟫';
                    state.gold += 15;
                    state.xp += 10;
                    state.wheatCount++;
                    checkQuests();
                    updateUI();
                }
            };
        });

        // Relógio
        setInterval(() => {
            state.time = (state.time + 1) % 24;
            document.getElementById('clock').innerText = `${state.time.toString().padStart(2, '0')}:00`;
            const night = document.getElementById('night-overlay');
            if(night) night.style.background = (state.time >= 19 || state.time <= 5) ? "rgba(0,0,50,0.5)" : "transparent";
        }, 10000);
    }

    function checkQuests() {
        const questText = document.getElementById('quest-text');
        if (state.wheatCount >= 3) {
            questText.innerHTML = "✅ Missão: Colha 3 trigos (Concluído!)";
        } else {
            questText.innerText = `Missão: Colha 3 trigos (${state.wheatCount}/3)`;
        }
    }

    function updateUI() {
        document.getElementById('gold-val').innerText = state.gold;
        document.getElementById('xp-val').innerText = state.xp;
        localStorage.setItem('fazenda_save_v2', JSON.stringify(state));
    }

    // MOVIMENTAÇÃO
    window.addEventListener('keydown', (e) => {
        if (gameContainer.style.display === 'none') return;

        const step = 25;
        const key = e.key.toLowerCase();

        if (key === 'w') state.pos.y -= step;
        if (key === 's') state.pos.y += step;
        if (key === 'a') { state.pos.x -= step; playerEl.style.transform = 'scaleX(-1)'; }
        if (key === 'd') { state.pos.x += step; playerEl.style.transform = 'scaleX(1)'; }

        updateCamera();
    });

    function updateCamera() {
        state.pos.x = Math.max(0, Math.min(state.pos.x, WORLD_SIZE - 40));
        state.pos.y = Math.max(0, Math.min(state.pos.y, WORLD_SIZE - 40));

        playerEl.style.left = state.pos.x + 'px';
        playerEl.style.top = state.pos.y + 'px';

        const camX = (window.innerWidth / 2) - state.pos.x;
        const camY = (window.innerHeight / 2) - state.pos.y;
        
        worldEl.style.left = camX + 'px';
        worldEl.style.top = camY + 'px';

        const mPlayer = document.getElementById('minimap-player');
        if(mPlayer) {
            mPlayer.style.left = (state.pos.x / WORLD_SIZE) * 150 + 'px';
            mPlayer.style.top = (state.pos.y / WORLD_SIZE) * 150 + 'px';
        }
    }
});