const gameArea = document.getElementById('game-area');
const scoreBoard = document.getElementById('score-board');
const menu = document.getElementById('menu');
const lanes = document.querySelectorAll('.lane');

let score = 0;
let speed = 4;
let isPlaying = false;
let tiles = [];

function startGame() {
    score = 0;
    speed = 4;
    isPlaying = true;
    tiles = [];
    gameArea.querySelectorAll('.tile').forEach(t => t.remove());
    scoreBoard.innerText = score;
    menu.style.display = 'none';
    
    spawnTile();
    update();
}

function spawnTile() {
    if (!isPlaying) return;
    
    const laneIndex = Math.floor(Math.random() * 4);
    const tile = document.createElement('div');
    tile.className = 'tile';
    tile.style.top = '-150px';
    
    tile.addEventListener('mousedown', (e) => {
        e.stopPropagation();
        if (!tile.classList.contains('hit')) {
            tile.classList.add('hit');
            score++;
            scoreBoard.innerText = score;
            speed += 0.1; // Aceleração gradual
            setTimeout(() => {
                tile.remove();
                tiles = tiles.filter(t => t !== tile);
            }, 200);
            spawnTile(); // Cria a próxima assim que clica nesta
        }
    });

    lanes[laneIndex].appendChild(tile);
    tiles.push(tile);
}

function update() {
    if (!isPlaying) return;

    for (let i = tiles.length - 1; i >= 0; i--) {
        const tile = tiles[i];
        let top = parseFloat(tile.style.top);
        top += speed;
        tile.style.top = top + 'px';

        // Perdeu: a peça passou do limite
        if (top > 550) {
            endGame();
            return;
        }
    }

    requestAnimationFrame(update);
}

// Perdeu: clicou na área errada
gameArea.addEventListener('mousedown', () => {
    if (isPlaying) endGame();
});

function endGame() {
    isPlaying = false;
    menu.style.display = 'flex';
    menu.querySelector('h1').innerText = "Fim de Jogo!";
    menu.querySelector('p').innerText = `Você fez ${score} pontos`;
}