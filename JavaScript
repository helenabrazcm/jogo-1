document.addEventListener('DOMContentLoaded', () => {
    const player = document.getElementById('player');
    const world = document.getElementById('world');
    
    let state = {
        gold: 0,
        wheat: 0,
        pos: { x: 1500, y: 1500 }, // Posição inicial no centro
        speed: 6,
        keys: {}
    };

    // Captura de teclado
    window.addEventListener('keydown', e => state.keys[e.key.toLowerCase()] = true);
    window.addEventListener('keyup', e => state.keys[e.key.toLowerCase()] = false);

    // Loop Principal do Jogo (60 FPS)
    function gameLoop() {
        update();
        draw();
        requestAnimationFrame(gameLoop);
    }

    function update() {
        let moving = false;
        let vx = 0;
        let vy = 0;

        // Lógica de Movimento
        if (state.keys['w'] || state.keys['arrowup']) { vy = -state.speed; moving = true; }
        if (state.keys['s'] || state.keys['arrowdown']) { vy = state.speed; moving = true; }
        if (state.keys['a'] || state.keys['arrowleft']) { 
            vx = -state.speed; 
            moving = true; 
            player.style.transform = 'scaleX(-1)'; // Vira para a esquerda
        }
        if (state.keys['d'] || state.keys['arrowright']) { 
            vx = state.speed; 
            moving = true; 
            player.style.transform = 'scaleX(1)'; // Vira para a direita
        }

        // Atualiza posição com base na velocidade
        state.pos.x += vx;
        state.pos.y += vy;

        // Limites do mapa (4000x4000)
        state.pos.x = Math.max(0, Math.min(3960, state.pos.x));
        state.pos.y = Math.max(0, Math.min(3960, state.pos.y));

        // Ativa animação de passos
        if (moving) {
            player.classList.add('walking');
        } else {
            player.classList.remove('walking');
        }
    }

    function draw() {
        // Posiciona o jogador no mundo
        player.style.left = state.pos.x + 'px';
        player.style.top = state.pos.y + 'px';

        // Calcula a posição da câmera para centralizar no jogador
        const camX = (window.innerWidth / 2) - state.pos.x;
        const camY = (window.innerHeight / 2) - state.pos.y;
        
        // Move o mundo inteiro (câmera)
        world.style.transform = `translate(${camX}px, ${camY}px)`;
    }

    // Mecânica de Plantação e Colheita
    document.querySelectorAll('.plot').forEach(plot => {
        plot.addEventListener('click', () => {
            // Calcula distância entre jogador e o canteiro
            const plotX = parseInt(plot.style.left);
            const plotY = parseInt(plot.style.top);
            const dist = Math.hypot(state.pos.x - plotX, state.pos.y - plotY);
            
            // Só interage se estiver perto (raio de 150px)
            if(dist > 150) {
                console.log("Muito longe para interagir!");
                return;
            }

            if (plot.innerText === '🟫') {
                // Fase 1: Plantar
                plot.innerText = '🌱';
                
                // Fase 2: Crescer (após 3 segundos)
                setTimeout(() => {
                    if(plot.innerText === '🌱') plot.innerText = '🌿';
                }, 3000);

                // Fase 3: Pronto para colher (após 6 segundos)
                setTimeout(() => {
                    if(plot.innerText === '🌿') plot.innerText = '🌾';
                }, 6000);

            } else if (plot.innerText === '🌾') {
                // Colher
                plot.innerText = '🟫';
                state.gold += 15;
                state.wheat += 1;
                updateUI();
            }
        });
    });

    function updateUI() {
        document.getElementById('ui-gold').innerText = state.gold;
        document.getElementById('ui-wheat').innerText = state.wheat;
    }

    // Iniciar o jogo
    gameLoop();
});