const board = document.getElementById('board');
const scoreElement = document.getElementById('score');
const overlay = document.getElementById('overlay');

let score = 0;
let gameSpeed = 3;
let gameActive = true;
let spawnInterval;
let moveInterval;

function init() {
    score = 0;
    gameSpeed = 3;
    gameActive = true;
    board.innerHTML = '';
    overlay.style.display = 'none';
    scoreElement.innerText = `Score: ${score}`;
    
    // Cria uma nova tecla a cada 700ms
    spawnInterval = setInterval(createTile, 700);
    // Atualiza a posição das teclas
    moveInterval = setInterval(moveTiles, 20);
}

function createTile() {
    if (!gameActive) return;
    const tile = document.createElement('div');
    const column = Math.floor(Math.random() * 4); // Escolhe uma das 4 colunas
    
    tile.classList.add('tile');
    tile.style.left = (column * 75) + 'px';
    tile.style.top = '-125px'; // Começa fora da tela (acima)
    
    tile.onclick = function(e) {
        e.stopPropagation(); // Impede o clique de chegar ao fundo
        score++;
        scoreElement.innerText = `Score: ${score}`;
        if (score % 10 === 0) gameSpeed += 0.5; // Aumenta dificuldade
        this.remove();
    };
    
    board.appendChild(tile);
}

function moveTiles() {
    if (!gameActive) return;
    const tiles = document.querySelectorAll('.tile');
    
    tiles.forEach(tile => {
        let top = parseFloat(tile.style.top);
        top += gameSpeed;
        tile.style.top = top + 'px';
        
        // Se a tecla passar do fundo sem ser clicada
        if (top > 500) {
            gameOver();
        }
    });
}

// Se clicar no fundo branco (fora da tecla preta), perde o jogo
board.parentElement.onclick = function() {
    if (gameActive) gameOver();
};

function gameOver() {
    gameActive = false;
    clearInterval(spawnInterval);
    clearInterval(moveInterval);
    overlay.style.display = 'flex';
}

function resetGame() {
    init();
}

// Iniciar o jogo pela primeira vez
init();