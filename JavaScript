// Estado Inicial
let gameState = {
    name: "Fazendeiro",
    skin: "🧑‍🌾",
    gold: 50,
    xp: 0,
    pos: { x: 400, y: 300 },
    inventory: { seeds: 5, wheat: 0, milk: 0 },
    quests: { wheatHarvested: 0, goal: 3 },
    time: 8
};

// --- TELAS E INICIALIZAÇÃO ---
function showCustomization() {
    document.getElementById('start-screen').style.display = 'none';
    document.getElementById('custom-screen').style.display = 'flex';
}

function setSkin(emoji) {
    gameState.skin = emoji;
    document.getElementById('preview').innerText = emoji;
}

function startGame() {
    gameState.name = document.getElementById('char-name').value || "Fazendeiro";
    document.getElementById('custom-screen').style.display = 'none';
    document.getElementById('game-container').style.display = 'block';
    initGame();
}

function initGame() {
    document.getElementById('player').innerText = gameState.skin;
    document.getElementById('display-name').innerText = gameState.name;
    updateUI();
    saveGame();
}

// --- SISTEMA DE SALVAMENTO ---
function saveGame() {
    localStorage.setItem('sertao_rpg_save', JSON.stringify(gameState));
}

function loadGame() {
    const saved = localStorage.getItem('sertao_rpg_save');
    if (saved) {
        gameState = JSON.parse(saved);
        document.getElementById('start-screen').style.display = 'none';
        document.getElementById('game-container').style.display = 'block';
        initGame();
        updatePlayerPos();
    } else {
        alert("Nenhum save encontrado!");
    }
}

// --- MOVIMENTAÇÃO E INPUT ---
window.addEventListener('keydown', (e) => {
    if (document.getElementById('game-container').style.display === 'none') return;
    
    const step = 20;
    if (e.key.toLowerCase() === 'e') toggleInventory();

    if (e.key === 'w') gameState.pos.y -= step;
    if (e.key === 's') gameState.pos.y += step;
    if (e.key === 'a') { gameState.pos.x -= step; document.getElementById('player').style.transform = 'scaleX(-1)'; }
    if (e.key === 'd') { gameState.pos.x += step; document.getElementById('player').style.transform = 'scaleX(1)'; }
    
    updatePlayerPos();
});

function updatePlayerPos() {
    const p = document.getElementById('player');
    p.style.top = gameState.pos.y + 'px';
    p.style.left = gameState.pos.x + 'px';
}

// --- MECÂNICAS ---
function interactPlot(plot) {
    if (plot.innerText === '🟫' && gameState.inventory.seeds > 0) {
        gameState.inventory.seeds--;
        plot.innerText = '🌱';
        setTimeout(() => plot.innerText = '🌾', 5000);
        updateUI();
    } else if (plot.innerText === '🌾') {
        plot.innerText = '🟫';
        gameState.inventory.wheat++;
        gameState.xp += 10;
        checkQuests();
        updateUI();
    }
}

function buySeed() {
    if (gameState.gold >= 10) {
        gameState.gold -= 10;
        gameState.inventory.seeds++;
        updateUI();
    }
}

function sellAll() {
    let profit = gameState.inventory.wheat * 20 + gameState.inventory.milk * 30;
    gameState.gold += profit;
    gameState.inventory.wheat = 0;
    gameState.inventory.milk = 0;
    updateUI();
    saveGame();
}

function checkQuests() {
    if (gameState.inventory.wheat >= gameState.quests.goal) {
        document.getElementById('quest-list').innerHTML = "✅ Missão Concluída!";
    } else {
        document.getElementById('quest-list').innerHTML = `Colha ${gameState.quests.goal} Trigos (${gameState.inventory.wheat}/${gameState.quests.goal})`;
    }
}

function updateUI() {
    document.getElementById('gold-val').innerText = gameState.gold;
    document.getElementById('xp-val').innerText = gameState.xp;
    document.getElementById('inv-content').innerHTML = `
        Sementes: ${gameState.inventory.seeds} | Trigo: ${gameState.inventory.wheat}
    `;
    saveGame();
}

function toggleInventory() {
    const inv = document.getElementById('inventory-menu');
    inv.style.display = inv.style.display === 'block' ? 'none' : 'block';
}

// Ciclo dia/noite simples
setInterval(() => {
    gameState.time = (gameState.time + 1) % 24;
    document.getElementById('clock').innerText = `${gameState.time.toString().padStart(2, '0')}:00`;
    document.getElementById('night-overlay').style.background = (gameState.time > 18 || gameState.time < 6) ? "rgba(0,0,50,0.4)" : "transparent";
}, 10000);

// Atualize o gameState para suportar um mundo maior
gameState.worldSize = 3000;

function updatePlayerPos() {
    const p = document.getElementById('player');
    const world = document.getElementById('world');
    const mPlayer = document.getElementById('minimap-player');

    // 1. Limitar o jogador dentro do mapa
    gameState.pos.x = Math.max(0, Math.min(gameState.pos.x, gameState.worldSize - 40));
    gameState.pos.y = Math.max(0, Math.min(gameState.pos.y, gameState.worldSize - 40));

    // 2. Mover o personagem no mundo
    p.style.top = gameState.pos.y + 'px';
    p.style.left = gameState.pos.x + 'px';

    // 3. Sistema de Câmera (Centraliza o jogador)
    const camX = window.innerWidth / 2 - gameState.pos.x;
    const camY = window.innerHeight / 2 - gameState.pos.y;
    world.style.transform = `translate(${camX}px, ${camY}px)`;

    // 4. Atualizar Mini-mapa (Proporcional)
    // Cálculo: (posição_atual / tamanho_total) * tamanho_minimapa
    const miniX = (gameState.pos.x / gameState.worldSize) * 150;
    const miniY = (gameState.pos.y / gameState.worldSize) * 150;
    mPlayer.style.left = miniX + 'px';
    mPlayer.style.top = miniY + 'px';
}

// Chame updatePlayerPos no startGame para inicializar a câmera
function startGame() {
    gameState.name = document.getElementById('char-name').value || "Fazendeiro";
    document.getElementById('custom-screen').style.display = 'none';
    document.getElementById('game-container').style.display = 'block';
    
    // Organizar elementos iniciais no mundo expandido
    initGame();
    updatePlayerPos(); 
}